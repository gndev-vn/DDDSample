{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MongoDB": {
    "ConnectionString": "mongodb://identity_user:identity_password@localhost:27017/identitydb?authSource=identitydb",
    "DatabaseName": "identitydb"
  },
  "JwtSettings": {
    "SecretKey": "your-super-secret-key-that-is-at-least-32-characters-long",
    "Issuer": "IdentityAPI",
    "Audience": "IdentityAPI-Users",
    "ExpirationInMinutes": 60
  },
  "RabbitMq": {
    "Host": "localhost",
    "Username": "guest",
    "Password": "guest"
  },
  "Hosting": {
    "Restful": {
      "Http": 5008,
      "Https": 5010
    },
    "Grpc": {
      "Http": 5009,
      "Https": 5011
    }
  },
  "AllowedHosts": "*"
}