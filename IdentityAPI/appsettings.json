{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Debug"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "your-super-secret-key-that-is-at-least-32-characters-long",
    "Issuer": "IdentityAPI",
    "Audience": "IdentityAPI-Users"
  },
  "Google": {
    "ClientId": ""
  },
  "Hosting": {
    "Restful": {
      "Http": 9088,
      "Https": 9090
    },
    "Grpc": {
      "Http": 9089,
      "Https": 9091
    }
  },
  "IdentitySeed": {
    "Enabled": true,
    "Admin": {
      "Username": "admin",
      "Email": "admin@example.com",
      "Password": "admin123",
      "FirstName": "Admin",
      "LastName": "User"
    },
    "User": {
      "Username": "user",
      "Email": "user@example.com",
      "Password": "user123",
      "FirstName": "Sample",
      "LastName": "User"
    }
  }
}
